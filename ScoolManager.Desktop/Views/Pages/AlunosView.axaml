<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScoolManager.Desktop.ViewModels.Pages"
             xmlns:models="using:ScoolManager.Desktop.Models"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Class="ScoolManager.Desktop.Views.Pages.AlunosView"
             x:DataType="vm:AlunosViewModel">

    <Design.DataContext>
        <vm:AlunosViewModel/>
    </Design.DataContext>

    <!-- ================================================================
         RECURSOS: mesma paleta usada em MainWindow.axaml / DashboardView.axaml
         (tema escuro / Material 3) — para manter a identidade visual da app.
         ================================================================ -->
    <UserControl.Resources>

        <SolidColorBrush x:Key="BackgroundBrush" Color="#0B1326"/>
        <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#131B2E"/>
        <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="#222A3D"/>
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#2D3449"/>

        <SolidColorBrush x:Key="OnSurfaceBrush" Color="#DAE2FD"/>
        <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#C2C6D6"/>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#ADC6FF"/>
        <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#4D8EFF"/>
        <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#00285D"/>
        <SolidColorBrush x:Key="OutlineVariantBrush" Color="#424754"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFB4AB"/>
        <SolidColorBrush x:Key="EmeraldBrush" Color="#34D399"/>

        <!-- Gradiente do "neo-card" (linear-gradient(145deg, #171f33, #111b2e)) -->
        <LinearGradientBrush x:Key="NeoCardGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#171F33" Offset="0"/>
            <GradientStop Color="#111B2E" Offset="1"/>
        </LinearGradientBrush>

    </UserControl.Resources>

    <!-- ================================================================
         ESTILOS
         ================================================================ -->
    <UserControl.Styles>

        <Style Selector="Border.neo-card">
            <Setter Property="Background" Value="{StaticResource NeoCardGradientBrush}"/>
            <Setter Property="BorderBrush" Value="#1A8C909F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BoxShadow" Value="inset 1 1 0 0 #0DFFFFFF, 8 8 16 0 #66000000"/>
        </Style>

        <Style Selector="Border.neo-card-inner">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BoxShadow" Value="inset 2 2 5 0 #80000000, inset -1 -1 2 0 #0DFFFFFF"/>
        </Style>

        <!-- Botão primário (ação principal, ex.: "Novo Aluno") -->
        <Style Selector="Button.primario">
            <Setter Property="Background" Value="{StaticResource PrimaryContainerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.primario:pointerover">
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        <Style Selector="Button.primario:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>

        <!-- Botão secundário (Importar, Mais Filtros, Exportar) -->
        <Style Selector="Button.secundario">
            <Setter Property="Background" Value="{StaticResource SurfaceContainerHighBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1A8C909F"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.secundario:pointerover">
            <Setter Property="Background" Value="{StaticResource SurfaceVariantBrush}"/>
        </Style>

        <!-- Link discreto dentro dos modais (Cancelar) -->
        <Style Selector="Button.link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.link:pointerover">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>

        <!-- IMPORTANTE: linha da tabela inteira é clicável (não existe botão "Ver Detalhes") -->
        <Style Selector="Button.linha">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.linha:pointerover">
            <Setter Property="Background" Value="#0DFFFFFF"/>
        </Style>
        <Style Selector="Button.linha:pressed">
            <Setter Property="Background" Value="#1A4D8EFF"/>
        </Style>

        <Style Selector="TextBlock.coluna-titulo">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
        </Style>

        <Style Selector="ComboBox.filtro">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Linha de documento no Passo 4 do wizard -->
        <Style Selector="Border.documento-card">
            <Setter Property="BorderBrush" Value="{StaticResource OutlineVariantBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

    </UserControl.Styles>

    <!-- ================================================================
         CONTEÚDO: Panel raiz para permitir o overlay dos modais por cima
         ================================================================ -->
    <Panel>

        <Grid Margin="32" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="20">

            <!-- ========================================================
                 CABEÇALHO
                 ======================================================== -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Gestão de Alunos" FontSize="24" FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Dashboard" FontSize="12" Opacity="0.6"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                        <TextBlock Text="›" FontSize="12" Opacity="0.4"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                        <TextBlock Text="Lista de Alunos" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Classes="secundario" Command="{Binding AbrirImportarAlunosCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <materialIcons:MaterialIcon Kind="Upload" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Importar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="primario" Command="{Binding AbrirNovoAlunoCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <materialIcons:MaterialIcon Kind="AccountPlus" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Novo Aluno" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ========================================================
                 PESQUISA + FILTROS + EXPORTAÇÃO
                 ======================================================== -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="16">

                <!-- Pesquisa -->
                <Border Grid.Column="0" Classes="neo-card-inner" Padding="16,4">
                    <Grid ColumnDefinitions="Auto,*">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="Magnify" Width="20" Height="20"
                                                     Foreground="{StaticResource OnSurfaceVariantBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchText}"
                                 PlaceholderText="Pesquisar por código, nome ou curso..."
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource OnSurfaceBrush}"
                                 VerticalAlignment="Center" Padding="0,10"/>
                    </Grid>
                </Border>

                <!-- Filtros + Mais Filtros + Exportar -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">

                    <Border Classes="neo-card-inner" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox Classes="filtro" ItemsSource="{Binding Classes}"
                                      SelectedItem="{Binding ClasseSelecionada}"/>
                            <Border Width="1" Margin="4,8" Background="{StaticResource OutlineVariantBrush}" Opacity="0.2"/>
                            <ComboBox Classes="filtro" ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding StatusSelecionado}"/>
                            <Border Width="1" Margin="4,8" Background="{StaticResource OutlineVariantBrush}" Opacity="0.2"/>
                            <ComboBox Classes="filtro" ItemsSource="{Binding AnosLetivos}"
                                      SelectedItem="{Binding AnoLetivoSelecionado}"/>
                        </StackPanel>
                    </Border>

                    <Button Classes="secundario" Command="{Binding AbrirFiltrosAvancadosCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <materialIcons:MaterialIcon Kind="FilterVariant" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Mais Filtros" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="secundario">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <materialIcons:MaterialIcon Kind="Download" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Exportar" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="2" MinWidth="160">
                                    <Button Classes="link" HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Content="Exportar PDF"
                                            Command="{Binding AbrirExportarPdfCommand}"/>
                                    <Button Classes="link" HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Content="Exportar Excel"
                                            Command="{Binding AbrirExportarExcelCommand}"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                </StackPanel>
            </Grid>

            <!-- ========================================================
                 TABELA DE ALUNOS

                 IMPORTANTE sobre o alinhamento: as colunas usam larguras
                 FIXAS (em vez de "*"/proporcional) e a MESMA string de
                 ColumnDefinitions no cabeçalho e nas linhas. Isto evita o
                 desalinhamento clássico causado pela barra de scroll: como
                 o cabeçalho fica fora do ScrollViewer, uma coluna "*"
                 calcularia uma largura diferente ali (sem a barra) e nas
                 linhas (com a barra), fazendo rótulo e valor "andarem"
                 um em relação ao outro. Com largura fixa, o espaço extra
                 (se houver) sobra depois da última coluna, sem deslocar
                 nada.
                 ======================================================== -->
            <Border Grid.Row="2" Classes="neo-card" Padding="0" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">

                    <!-- Cabeçalho da tabela -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceContainerHighBrush}"
                            Padding="20,14" BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource OutlineVariantBrush}">
                        <Grid ColumnDefinitions="130,280,150,170,110">
                            <TextBlock Grid.Column="0" Classes="coluna-titulo" Text="CÓDIGO"/>
                            <TextBlock Grid.Column="1" Classes="coluna-titulo" Text="NOME"/>
                            <TextBlock Grid.Column="2" Classes="coluna-titulo" Text="CLASSE"/>
                            <TextBlock Grid.Column="3" Classes="coluna-titulo" Text="CURSO"/>
                            <TextBlock Grid.Column="4" Classes="coluna-titulo" Text="SALA"/>
                        </Grid>
                    </Border>

                    <!-- Linhas: cada linha é um Button inteiro (clicável), sem botão "Ver Detalhes" -->
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Alunos}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:AlunoListItemModel">
                                    <Button Classes="linha"
                                            Command="{Binding $parent[ItemsControl].((vm:AlunosViewModel)DataContext).AbrirDetalhesCommand}"
                                            CommandParameter="{Binding}">
                                        <!-- Mesma string de larguras do cabeçalho (130,280,150,170,110);
                                             a 6ª coluna (Auto) é só o chevron e não existe no cabeçalho,
                                             por isso não afeta o alinhamento das colunas de dados. -->
                                        <Grid ColumnDefinitions="130,280,150,170,110,Auto">

                                            <TextBlock Grid.Column="0" Text="{Binding Codigo}"
                                                       VerticalAlignment="Center" FontSize="13" Opacity="0.8"
                                                       Foreground="{StaticResource OnSurfaceBrush}"/>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                                        VerticalAlignment="Center">
                                                <Border Width="32" Height="32" CornerRadius="999"
                                                        Background="{StaticResource SurfaceVariantBrush}"
                                                        BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="1">
                                                    <TextBlock Text="{Binding Iniciais}" FontSize="12" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{StaticResource OnSurfaceBrush}"/>
                                                </Border>
                                                <TextBlock Text="{Binding Nome}" FontSize="14" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource OnSurfaceBrush}"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" Text="{Binding Classe}"
                                                       VerticalAlignment="Center" FontSize="13"
                                                       Foreground="{StaticResource OnSurfaceVariantBrush}"/>

                                            <TextBlock Grid.Column="3" Text="{Binding Curso}"
                                                       VerticalAlignment="Center" FontSize="13"
                                                       Foreground="{StaticResource OnSurfaceVariantBrush}"/>

                                            <TextBlock Grid.Column="4" Text="{Binding Sala}"
                                                       VerticalAlignment="Center" FontSize="13"
                                                       Foreground="{StaticResource OnSurfaceVariantBrush}"/>

                                            <materialIcons:MaterialIcon Grid.Column="5" Kind="ChevronRight"
                                                                         Width="18" Height="18" Opacity="0.4"
                                                                         VerticalAlignment="Center"
                                                                         Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ========================================================
                 RODAPÉ / PAGINAÇÃO
                 ======================================================== -->
            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding ResumoExibicaoLabel}"
                           FontSize="12" Opacity="0.6" VerticalAlignment="Center"
                           Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                <!-- TODO: paginação real quando a fonte de dados deixar de ser mock -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Classes="secundario" Padding="8" IsEnabled="False">
                        <materialIcons:MaterialIcon Kind="ChevronLeft" Width="16" Height="16"/>
                    </Button>
                    <Button Classes="primario" Padding="8" Content="1" MinWidth="32"
                            HorizontalContentAlignment="Center"/>
                    <Button Classes="secundario" Padding="8" IsEnabled="False">
                        <materialIcons:MaterialIcon Kind="ChevronRight" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- ================================================================
             OVERLAY DOS MODAIS (Novo Aluno em passos, Importar, Exportar
             PDF/Excel, Filtros Avançados) — implementados aqui como um
             overlay leve para não depender de novos ficheiros de View.
             ================================================================ -->
        <Border Background="#99000000" IsVisible="{Binding AlgumModalAberto}" ZIndex="500">
          <Panel>

            <!-- O modal "Novo Aluno" é mais largo (tem mais campos) do que
                 os demais, por isso fica num Border próprio. -->
            <Border Classes="neo-card" MaxWidth="620" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="{Binding IsNovoAlunoAberto}">
                <StackPanel Spacing="16">

                    <!-- Cabeçalho do wizard + indicador de progresso -->
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Nova matrícula" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource OnSurfaceBrush}"/>
                                <TextBlock Text="{Binding TituloPassoAtual}" FontSize="13" Opacity="0.7"
                                           Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.6"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}">
                                <Run Text="Passo "/><Run Text="{Binding PassoAtual}"/><Run Text=" de 4"/>
                            </TextBlock>
                        </Grid>
                        <ProgressBar Minimum="1" Maximum="4" Value="{Binding PassoAtual}" Height="4"
                                     Foreground="{StaticResource PrimaryContainerBrush}"
                                     Background="{StaticResource SurfaceVariantBrush}"/>
                    </StackPanel>

                    <ScrollViewer MaxHeight="440">
                        <StackPanel Spacing="14">

                            <!-- ============== Passo 1: Dados do Aluno ============== -->
                            <StackPanel Spacing="12" IsVisible="{Binding EhPasso1}">
                                <TextBox Text="{Binding NomeCompleto}" PlaceholderText="Nome completo do aluno *"/>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <DatePicker Grid.Column="0" SelectedDate="{Binding DataNascimento}"/>
                                    <ComboBox Grid.Column="1" PlaceholderText="Sexo"
                                              ItemsSource="{Binding OpcoesSexo}" SelectedItem="{Binding Sexo}"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <TextBox Grid.Column="0" Text="{Binding Naturalidade}" PlaceholderText="Naturalidade"/>
                                    <TextBox Grid.Column="1" Text="{Binding Provincia}" PlaceholderText="Província"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <TextBox Grid.Column="0" Text="{Binding Pais}" PlaceholderText="País"/>
                                    <TextBox Grid.Column="1" Text="{Binding NumeroBiCedulaAluno}" PlaceholderText="Nº do BI ou Cédula"/>
                                </Grid>
                                <TextBox Text="{Binding Morada}" PlaceholderText="Morada"/>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Sofre de alguma doença?" FontSize="13"
                                               Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <RadioButton Content="Não" GroupName="Doenca" IsChecked="{Binding SofreDoencaNao}"/>
                                        <RadioButton Content="Sim" GroupName="Doenca" IsChecked="{Binding SofreDoencaSim}"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding QualDoenca}" PlaceholderText="Qual?"
                                             IsEnabled="{Binding SofreDoencaSim}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- ============== Passo 2: Dados dos Encarregados ============== -->
                            <StackPanel Spacing="12" IsVisible="{Binding EhPasso2}">
                                <TextBlock Text="Pai" Classes="coluna-titulo"/>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <TextBox Grid.Column="0" Text="{Binding NomePai}" PlaceholderText="Nome do pai"/>
                                    <TextBox Grid.Column="1" Text="{Binding ProfissaoPai}" PlaceholderText="Profissão do pai"/>
                                </Grid>
                                <TextBox Text="{Binding ContactoPai}" PlaceholderText="Contacto do pai"/>

                                <TextBlock Text="Mãe" Classes="coluna-titulo" Margin="0,8,0,0"/>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <TextBox Grid.Column="0" Text="{Binding NomeMae}" PlaceholderText="Nome da mãe"/>
                                    <TextBox Grid.Column="1" Text="{Binding ProfissaoMae}" PlaceholderText="Profissão da mãe"/>
                                </Grid>
                                <TextBox Text="{Binding ContactoMae}" PlaceholderText="Contacto da mãe"/>
                            </StackPanel>

                            <!-- ============== Passo 3: Enquadramento na Instituição ============== -->
                            <StackPanel Spacing="12" IsVisible="{Binding EhPasso3}">
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <ComboBox Grid.Column="0" PlaceholderText="Classe a frequentar *"
                                              ItemsSource="{Binding ClassesDisponiveis}"
                                              SelectedItem="{Binding ClasseMatricula}"/>
                                    <TextBox Grid.Column="1" Text="{Binding CursoMatricula}" PlaceholderText="Curso"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <ComboBox Grid.Column="0" PlaceholderText="Turno"
                                              ItemsSource="{Binding OpcoesTurno}" SelectedItem="{Binding Turno}"/>
                                    <ComboBox Grid.Column="1" PlaceholderText="Período"
                                              ItemsSource="{Binding OpcoesPeriodo}" SelectedItem="{Binding Periodo}"/>
                                </Grid>
                                <TextBox Text="{Binding SalaMatricula}" PlaceholderText="Sala / Turma"/>
                            </StackPanel>

                            <!-- ============== Passo 4: Documentos ============== -->
                            <StackPanel Spacing="10" IsVisible="{Binding EhPasso4}">

                                <Border Classes="documento-card">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <materialIcons:MaterialIcon Grid.Column="0" Kind="FileDocumentOutline"
                                                                     Width="22" Height="22" VerticalAlignment="Center"
                                                                     Foreground="{StaticResource PrimaryBrush}"/>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Certificado / Declaração" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource OnSurfaceBrush}"/>
                                            <TextBlock Text="{Binding CertificadoDeclaracaoNomeArquivo}" FontSize="12" Opacity="0.6"
                                                       Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Classes="secundario" Content="Selecionar" Padding="12,8"
                                                Click="OnSelecionarCertificadoClick"/>
                                    </Grid>
                                </Border>

                                <Border Classes="documento-card">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <materialIcons:MaterialIcon Grid.Column="0" Kind="AccountBoxOutline"
                                                                     Width="22" Height="22" VerticalAlignment="Center"
                                                                     Foreground="{StaticResource PrimaryBrush}"/>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Foto Tipo Passe" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource OnSurfaceBrush}"/>
                                            <TextBlock Text="{Binding FotoTipoPasseNomeArquivo}" FontSize="12" Opacity="0.6"
                                                       Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Classes="secundario" Content="Selecionar" Padding="12,8"
                                                Click="OnSelecionarFotoClick"/>
                                    </Grid>
                                </Border>

                                <Border Classes="documento-card">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <materialIcons:MaterialIcon Grid.Column="0" Kind="CardAccountDetailsOutline"
                                                                     Width="22" Height="22" VerticalAlignment="Center"
                                                                     Foreground="{StaticResource PrimaryBrush}"/>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="BI / Cédula *" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource OnSurfaceBrush}"/>
                                            <TextBlock Text="{Binding BiCedulaNomeArquivo}" FontSize="12" Opacity="0.6"
                                                       Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Classes="secundario" Content="Selecionar" Padding="12,8"
                                                Click="OnSelecionarBiCedulaClick"/>
                                    </Grid>
                                </Border>

                                <Border Classes="documento-card">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <materialIcons:MaterialIcon Grid.Column="0" Kind="HeartPulse"
                                                                     Width="22" Height="22" VerticalAlignment="Center"
                                                                     Foreground="{StaticResource PrimaryBrush}"/>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="Atestado Médico" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource OnSurfaceBrush}"/>
                                            <TextBlock Text="{Binding AtestadoMedicoNomeArquivo}" FontSize="12" Opacity="0.6"
                                                       Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Classes="secundario" Content="Selecionar" Padding="12,8"
                                                Click="OnSelecionarAtestadoClick"/>
                                    </Grid>
                                </Border>

                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Navegação do wizard -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                        <Button Grid.Column="0" Classes="link" Content="Cancelar"
                                Command="{Binding FecharModalCommand}"/>
                        <Button Grid.Column="2" Classes="secundario" Content="Voltar"
                                Command="{Binding PassoAnteriorCommand}"
                                IsVisible="{Binding PodeVoltar}"/>
                        <Button Grid.Column="3" Classes="primario"
                                Content="{Binding TextoBotaoAvancar}"
                                Command="{Binding AvancarOuConcluirCommand}"
                                IsEnabled="{Binding PodeAvancar}"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Demais modais (mais simples, mantêm o layout anterior) -->
            <Border Classes="neo-card" MaxWidth="480" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="{Binding !IsNovoAlunoAberto}">
                <StackPanel Spacing="18">

                    <!-- Importar Alunos -->
                    <StackPanel Spacing="14" IsVisible="{Binding IsImportarAlunosAberta}">
                        <TextBlock Text="Importar alunos" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource OnSurfaceBrush}"/>
                        <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="1.5"
                                CornerRadius="10" Padding="24">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <materialIcons:MaterialIcon Kind="CloudUpload" Width="32" Height="32"
                                                             HorizontalAlignment="Center"
                                                             Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="Arraste um ficheiro CSV/Excel ou clique para selecionar"
                                           TextAlignment="Center" TextWrapping="Wrap" FontSize="13" Opacity="0.7"
                                           Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Button Grid.Column="1" Classes="link" Content="Cancelar"
                                    Command="{Binding FecharModalCommand}"/>
                            <Button Grid.Column="2" Classes="primario" Content="Importar"
                                    Command="{Binding ConfirmarImportarAlunosCommand}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Exportar PDF -->
                    <StackPanel Spacing="14" IsVisible="{Binding IsExportarPdfAberta}">
                        <TextBlock Text="Exportar lista em PDF" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource OnSurfaceBrush}"/>
                        <TextBlock Text="Serão exportados os alunos visíveis com os filtros atuais."
                                   FontSize="13" Opacity="0.7" TextWrapping="Wrap"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Button Grid.Column="1" Classes="link" Content="Cancelar"
                                    Command="{Binding FecharModalCommand}"/>
                            <Button Grid.Column="2" Classes="primario" Content="Exportar"
                                    Command="{Binding ConfirmarExportarPdfCommand}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Exportar Excel -->
                    <StackPanel Spacing="14" IsVisible="{Binding IsExportarExcelAberta}">
                        <TextBlock Text="Exportar lista em Excel" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource OnSurfaceBrush}"/>
                        <TextBlock Text="Serão exportados os alunos visíveis com os filtros atuais."
                                   FontSize="13" Opacity="0.7" TextWrapping="Wrap"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Button Grid.Column="1" Classes="link" Content="Cancelar"
                                    Command="{Binding FecharModalCommand}"/>
                            <Button Grid.Column="2" Classes="primario" Content="Exportar"
                                    Command="{Binding ConfirmarExportarExcelCommand}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Filtros Avançados -->
                    <StackPanel Spacing="14" IsVisible="{Binding IsFiltrosAvancadosAberta}">
                        <TextBlock Text="Filtros avançados" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource OnSurfaceBrush}"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <DatePicker Grid.Column="0"/>
                            <DatePicker Grid.Column="1"/>
                        </Grid>
                        <TextBox PlaceholderText="Situação financeira (ex.: em atraso)"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Button Grid.Column="1" Classes="link" Content="Cancelar"
                                    Command="{Binding FecharModalCommand}"/>
                            <Button Grid.Column="2" Classes="primario" Content="Aplicar"
                                    Command="{Binding ConfirmarFiltrosAvancadosCommand}"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </Border>

          </Panel>
        </Border>

    </Panel>

</UserControl>
